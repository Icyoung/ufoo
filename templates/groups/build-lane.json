{
  "schema_version": 1,
  "template": {
    "id": "build-lane",
    "alias": "build-lane",
    "name": "Build Lane",
    "description": "Default engineering lane: architect/PMO plans phased work, builder implements, reviewer validates review and QA gates."
  },
  "defaults": {
    "launch_mode": "auto",
    "start_timeout_ms": 15000
  },
  "agents": [
    {
      "id": "architect",
      "nickname": "architect",
      "type": "auto",
      "role": "act as build-lane architect/PMO: design the solution as phased multi-agent work, assign ownership/dependencies/handoffs, and define when each phase is ready for review/QA test handoff",
      "prompt_profile": "system-architect",
      "accept_from": [
        "builder",
        "reviewer"
      ],
      "report_to": [
        "builder",
        "reviewer"
      ],
      "startup_order": 1,
      "depends_on": []
    },
    {
      "id": "builder",
      "nickname": "builder",
      "type": "auto",
      "role": "implement approved slices",
      "prompt_profile": "implementation-lead",
      "accept_from": [
        "architect",
        "reviewer"
      ],
      "report_to": [
        "reviewer"
      ],
      "startup_order": 2,
      "depends_on": [
        "architect"
      ]
    },
    {
      "id": "reviewer",
      "nickname": "reviewer",
      "type": "auto",
      "role": "review code correctness, release risk, regression coverage, and user-flow QA",
      "prompt_profile": "review-critic",
      "accept_from": [
        "architect",
        "builder"
      ],
      "report_to": [
        "builder",
        "architect"
      ],
      "startup_order": 3,
      "depends_on": [
        "architect",
        "builder"
      ]
    }
  ],
  "edges": [
    {
      "from": "architect",
      "to": "builder",
      "kind": "task"
    },
    {
      "from": "builder",
      "to": "reviewer",
      "kind": "review"
    },
    {
      "from": "reviewer",
      "to": "builder",
      "kind": "task"
    },
    {
      "from": "reviewer",
      "to": "architect",
      "kind": "task"
    }
  ]
}
