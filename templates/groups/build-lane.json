{
  "schema_version": 1,
  "template": {
    "id": "build-lane",
    "alias": "build-lane",
    "name": "Build Lane",
    "description": "Default engineering lane: plan, implement, review, and QA one scoped change."
  },
  "defaults": {
    "launch_mode": "auto",
    "start_timeout_ms": 15000
  },
  "agents": [
    {
      "id": "architect",
      "nickname": "architect",
      "type": "auto",
      "role": "define slices and architecture constraints",
      "prompt_profile": "system-architect",
      "accept_from": [
        "builder",
        "reviewer"
      ],
      "report_to": [
        "builder",
        "reviewer"
      ],
      "startup_order": 1,
      "depends_on": []
    },
    {
      "id": "builder",
      "nickname": "builder",
      "type": "auto",
      "role": "implement approved slices",
      "prompt_profile": "implementation-lead",
      "accept_from": [
        "architect",
        "reviewer",
        "qa"
      ],
      "report_to": [
        "reviewer"
      ],
      "startup_order": 2,
      "depends_on": [
        "architect"
      ]
    },
    {
      "id": "reviewer",
      "nickname": "reviewer",
      "type": "auto",
      "role": "review code correctness and release risk before QA",
      "prompt_profile": "review-critic",
      "accept_from": [
        "architect",
        "builder",
        "qa"
      ],
      "report_to": [
        "builder",
        "qa"
      ],
      "startup_order": 3,
      "depends_on": [
        "architect",
        "builder"
      ]
    },
    {
      "id": "qa",
      "nickname": "qa",
      "type": "auto",
      "role": "validate the implemented change from user-flow and regression perspectives",
      "prompt_profile": "qa-driver",
      "accept_from": [
        "builder",
        "reviewer"
      ],
      "report_to": [
        "builder",
        "reviewer"
      ],
      "startup_order": 4,
      "depends_on": [
        "architect",
        "builder",
        "reviewer"
      ]
    }
  ],
  "edges": [
    {
      "from": "architect",
      "to": "builder",
      "kind": "task"
    },
    {
      "from": "builder",
      "to": "reviewer",
      "kind": "review"
    },
    {
      "from": "reviewer",
      "to": "builder",
      "kind": "task"
    },
    {
      "from": "reviewer",
      "to": "qa",
      "kind": "review"
    },
    {
      "from": "qa",
      "to": "builder",
      "kind": "task"
    }
  ]
}
