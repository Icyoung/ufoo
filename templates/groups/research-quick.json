{
  "schema_version": 1,
  "template": {
    "id": "research-quick",
    "alias": "research-quick",
    "name": "Research Quick"
  },
  "defaults": {
    "launch_mode": "auto",
    "start_timeout_ms": 10000
  },
  "agents": [
    {
      "id": "researcher",
      "nickname": "researcher",
      "type": "claude",
      "role": "collect references and summarize findings",
      "prompt_profile": "research-scan",
      "accept_from": [],
      "report_to": [],
      "startup_order": 1,
      "depends_on": []
    },
    {
      "id": "coder",
      "nickname": "coder",
      "type": "codex",
      "role": "prototype and verify implementation",
      "prompt_profile": "rapid-prototype",
      "accept_from": [
        "researcher"
      ],
      "report_to": [
        "researcher"
      ],
      "startup_order": 2,
      "depends_on": [
        "researcher"
      ]
    }
  ],
  "edges": [
    {
      "from": "researcher",
      "to": "coder",
      "kind": "task"
    }
  ]
}
