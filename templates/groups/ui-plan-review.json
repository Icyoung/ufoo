{
  "schema_version": 1,
  "template": {
    "id": "ui-plan-review",
    "alias": "ui-plan-review",
    "name": "UI Plan Preflight",
    "description": "Pre-implementation UI/UX plan review that hardens a proposed frontend plan before build."
  },
  "defaults": {
    "launch_mode": "auto",
    "start_timeout_ms": 15000
  },
  "agents": [
    {
      "id": "planner",
      "nickname": "planner",
      "type": "auto",
      "role": "review UI and UX plan before implementation",
      "prompt_profile": "ui-plan-critic",
      "accept_from": [
        "challenger",
        "architect"
      ],
      "report_to": [
        "challenger",
        "architect"
      ],
      "startup_order": 1,
      "depends_on": []
    },
    {
      "id": "challenger",
      "nickname": "challenger",
      "type": "auto",
      "role": "challenge scope, complexity, and product leverage",
      "prompt_profile": "scope-challenger",
      "accept_from": [
        "planner",
        "architect"
      ],
      "report_to": [
        "architect"
      ],
      "startup_order": 2,
      "depends_on": [
        "planner"
      ]
    },
    {
      "id": "architect",
      "nickname": "architect",
      "type": "auto",
      "role": "turn reviewed UI plan into frontend implementation constraints, not code changes",
      "prompt_profile": "system-architect",
      "accept_from": [
        "planner",
        "challenger"
      ],
      "report_to": [],
      "startup_order": 3,
      "depends_on": [
        "planner",
        "challenger"
      ]
    }
  ],
  "edges": [
    {
      "from": "planner",
      "to": "challenger",
      "kind": "review"
    },
    {
      "from": "planner",
      "to": "architect",
      "kind": "task"
    },
    {
      "from": "challenger",
      "to": "architect",
      "kind": "review"
    }
  ]
}
