{
  "schema_version": 1,
  "template": {
    "id": "design-system",
    "alias": "design-system",
    "name": "Design System Planning",
    "description": "Pre-implementation design planning lane that defines visual system constraints; it does not edit UI code."
  },
  "defaults": {
    "launch_mode": "auto",
    "start_timeout_ms": 15000
  },
  "agents": [
    {
      "id": "consultant",
      "nickname": "consultant",
      "type": "auto",
      "role": "define product design direction and visual system",
      "prompt_profile": "design-system-consultant",
      "accept_from": [
        "challenger",
        "architect"
      ],
      "report_to": [
        "challenger",
        "architect"
      ],
      "startup_order": 1,
      "depends_on": []
    },
    {
      "id": "challenger",
      "nickname": "challenger",
      "type": "auto",
      "role": "challenge scope, complexity, and overbuilt brand work",
      "prompt_profile": "scope-challenger",
      "accept_from": [
        "consultant",
        "architect"
      ],
      "report_to": [
        "architect"
      ],
      "startup_order": 2,
      "depends_on": [
        "consultant"
      ]
    },
    {
      "id": "architect",
      "nickname": "architect",
      "type": "auto",
      "role": "turn design system rules into implementation constraints, not code changes",
      "prompt_profile": "system-architect",
      "accept_from": [
        "consultant",
        "challenger"
      ],
      "report_to": [],
      "startup_order": 3,
      "depends_on": [
        "consultant",
        "challenger"
      ]
    }
  ],
  "edges": [
    {
      "from": "consultant",
      "to": "challenger",
      "kind": "review"
    },
    {
      "from": "consultant",
      "to": "architect",
      "kind": "task"
    },
    {
      "from": "challenger",
      "to": "architect",
      "kind": "review"
    }
  ]
}
